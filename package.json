{
  "name": "transportadora-moura",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/generated/*"
  ],
  "type": "module",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "dev": "pnpm docker:postgres && concurrently -k -n api,web -c cyan,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "build": "nx run-many -t build",
    "build:web": "nx run-many -t build --projects=generated-api-types,web",
    "check-types": "nx run-many -t check-types",
    "dev:web": "pnpm --filter web dev --host localhost",
    "dev:api": "dotnet watch --project apps/api/Api.csproj run --no-launch-profile",
    "docker:postgres": "docker compose --env-file apps/api/.env --env-file apps/web/.env up -d postgres",
    "docker-compose:up": "docker compose --env-file apps/api/.env --env-file apps/web/.env up --build",
    "docker-compose:down": "docker compose --env-file apps/api/.env --env-file apps/web/.env down",
    "docker-compose:reset": "docker compose --env-file apps/api/.env --env-file apps/web/.env down -v",
    "prepare": "nx g @nx-dotnet/core:restore"
  },
  "dependencies": {
    "@transportadora-moura/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx-dotnet/core": "^3.0.2",
    "@nx/dotnet": "^22.7.5",
    "@nx/eslint": "21.4.1",
    "@nx/eslint-plugin": "21.4.1",
    "@nx/js": "21.6.11",
    "@openapitools/openapi-generator-cli": "^2.13.4",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@transportadora-moura/config": "workspace:*",
    "@types/node": "20.19.9",
    "concurrently": "^10.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "^21.5.2",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.29.0"
  },
  "packageManager": "pnpm@10.32.0"
}
