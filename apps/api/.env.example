ASPNETCORE_ENVIRONMENT=Development
API_HTTP_PORT=5086
FRONTEND_ORIGIN=http://localhost:3001,http://127.0.0.1:3001

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=transportadora_moura
POSTGRES_USER=transportadora
POSTGRES_PASSWORD=transportadora

# Optional override. When empty, the API builds the connection string from POSTGRES_* values.
ConnectionStrings__Transportadora=

# JWT authentication (required)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
Jwt__Issuer=transportadora-moura-api
Jwt__Audience=transportadora-moura-web
Jwt__ExpirationHours=8
Jwt__CookieName=auth_token

# Logging (Serilog) - optional overrides
# LOG_LEVEL sets the global minimum level (e.g., Debug, Information, Warning, Error)
# LOG_FILE_PATH enables file sink; empty or unset = console only
#LOG_LEVEL=Information
#LOG_FILE_PATH=logs/api-.log
