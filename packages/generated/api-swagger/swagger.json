{
  "openapi": "3.0.1",
  "info": {
    "title": "Transportadora Moura - Gestão de Coletas",
    "description": "API para cadastro, roteirização, ocorrências e acompanhamento de solicitações de coleta.",
    "version": "v1"
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate an operational user",
        "operationId": "Login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthenticatedUserDto" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "End the current session",
        "operationId": "Logout",
        "responses": {
          "204": { "description": "No Content" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get the authenticated user",
        "operationId": "GetCurrentUser",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthenticatedUserDto" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/collections": {
      "get": {
        "tags": ["Collections"],
        "summary": "List operational collections",
        "operationId": "ListCollections",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["Open", "InProgress", "Collected", "Cancelled"] } },
          { "name": "customerId", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "startDate", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "endDate", "in": "query", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/CollectionSummaryDto" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Collections"],
        "summary": "Create a collection request",
        "operationId": "CreateCollection",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCollectionRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CollectionDetailsDto" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/collections/{id}/incidents": {
      "post": {
        "tags": ["Collections"],
        "summary": "Register an operational incident",
        "operationId": "RegisterIncident",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterIncidentRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CollectionDetailsDto" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/customers": {
      "get": {
        "tags": ["Operational catalog"],
        "summary": "List customers available for collections",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/OptionDto" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "AuthenticatedUserDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "RegisterIncidentRequest": {
        "type": "object",
        "properties": {
          "description": { "type": "string" }
        },
        "required": ["description"]
      },
      "CollectionSummaryDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "number": { "type": "string" },
          "customerId": { "type": "string", "format": "uuid" },
          "customerName": { "type": "string" },
          "status": { "type": "string" },
          "priority": { "type": "string" },
          "overdue": { "type": "boolean" }
        }
      },
      "CollectionDetailsDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "incidents": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IncidentDto" }
          }
        }
      },
      "IncidentDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "description": { "type": "string" },
          "responsibleUser": { "type": "string" },
          "registeredAt": { "type": "string", "format": "date-time" }
        }
      },
      "CreateCollectionRequest": {
        "type": "object",
        "properties": {
          "customerId": { "type": "string", "format": "uuid" },
          "senderName": { "type": "string" },
          "expectedPickupDate": { "type": "string", "format": "date" }
        }
      },
      "OptionDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
