{
  "openapi": "3.0.1",
  "info": {
    "title": "Transportadora Moura - Gestão de Coletas",
    "description": "API para cadastro, roteirização, ocorrências e acompanhamento de solicitações de coleta.",
    "version": "v1"
  },
  "paths": {
    "/api/clientes": {
      "get": {
        "tags": ["Cadastros operacionais"],
        "summary": "Lista clientes disponíveis para coletas",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OptionDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/motoristas": {
      "get": {
        "tags": ["Cadastros operacionais"],
        "summary": "Lista motoristas disponíveis para atribuição",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OptionDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/veiculos": {
      "get": {
        "tags": ["Cadastros operacionais"],
        "summary": "Lista veículos disponíveis para atribuição",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/VeiculoOptionDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/coletas": {
      "get": {
        "tags": ["Coletas"],
        "summary": "Lista coletas operacionais",
        "description": "Lista coletas com filtros por status, cliente e período. Retorna também flags de prioridade e atraso para acompanhamento operacional.",
        "operationId": "ListarColetas",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "enum": ["Aberta", "EmColeta", "Coletada", "Cancelada"],
              "type": "string"
            }
          },
          {
            "name": "clienteId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "dataInicial",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dataFinal",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ColetaResumoDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Coletas"],
        "summary": "Cria uma solicitação de coleta",
        "description": "Cria uma coleta com status Aberta, número único e prioridade normal quando a prioridade não for informada.",
        "operationId": "CriarColeta",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CriarColetaRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColetaDetalheDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/coletas/{id}": {
      "get": {
        "tags": ["Coletas"],
        "summary": "Obtém detalhe de uma coleta",
        "description": "Retorna dados completos da coleta, atribuição operacional e ocorrências em ordem cronológica.",
        "operationId": "ObterColeta",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColetaDetalheDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/coletas/{id}/atribuicao": {
      "post": {
        "tags": ["Coletas"],
        "summary": "Atribui motorista e veículo",
        "description": "Vincula motorista e veículo a uma coleta ativa. Coletas canceladas não aceitam atribuição.",
        "operationId": "AtribuirColeta",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AtribuirColetaRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColetaDetalheDto"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/coletas/{id}/iniciar": {
      "post": {
        "tags": ["Coletas"],
        "summary": "Marca uma coleta como EmColeta",
        "description": "Avança uma coleta Aberta para EmColeta somente quando motorista e veículo já estão vinculados.",
        "operationId": "IniciarColeta",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColetaDetalheDto"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/coletas/{id}/concluir": {
      "post": {
        "tags": ["Coletas"],
        "summary": "Marca uma coleta como Coletada",
        "description": "Conclui uma coleta em execução somente quando motorista e veículo estão vinculados.",
        "operationId": "ConcluirColeta",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColetaDetalheDto"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/coletas/{id}/cancelar": {
      "post": {
        "tags": ["Coletas"],
        "summary": "Cancela uma coleta",
        "description": "Cancela uma coleta ativa. O status Cancelada é terminal e não retorna ao fluxo operacional.",
        "operationId": "CancelarColeta",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelarColetaRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColetaDetalheDto"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/coletas/{id}/ocorrencias": {
      "post": {
        "tags": ["Coletas"],
        "summary": "Registra ocorrência operacional",
        "description": "Registra ocorrência com descrição, data/hora do servidor e usuário responsável informado.",
        "operationId": "RegistrarOcorrencia",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrarOcorrenciaRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColetaDetalheDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
